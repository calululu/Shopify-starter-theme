{
  "name": "shopify-starter-theme",
  "version": "1.0.0",
  "description": "Starter theme for shopify with Tailwind and Vite",
  "keywords": [
    "vite",
    "tailwind",
    "shopify"
  ],
  "license": "ISC",
  "author": "calulu",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "tailwind": "npx @tailwindcss/cli -i ./src/css/main.css -o ./assets/main.css --watch",
    "shopify": "shopify theme dev --theme-editor-sync",
    "build": "npx vite build",
    "dev:build": "vite build --watch"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "gsap": "^3.15.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "vite": "^8.0.16"
  }
}
