      "presentation": {
        "group": "dev-servers",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Dev Environment",
      "dependsOn": ["Tailwind Watch", "Vite Watch", "Shopify Theme Dev"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
