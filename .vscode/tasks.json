{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Tailwind Watch",
      "type": "shell",
      "command": "npx",
      "args": [
        "@tailwindcss/cli",
        "-i",
        "./src/css/main.css",
        "-o",
        "./assets/main.css",
        "--watch"
      ],
      "presentation": {
        "group": "dev-servers",
        "reveal": "always",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Vite Watch",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev:js"],
      "presentation": {
        "group": "dev-servers",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Shopify Theme Dev",
      "type": "shell",
      "command": "shopify",
      "args": ["theme", "dev"],
      "presentation": {
        "group": "dev-servers",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Dev Environment",
      "dependsOn": ["Tailwind Watch", "Vite Watch", "Shopify Theme Dev"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
